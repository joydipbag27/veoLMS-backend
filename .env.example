# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173
SESSION_SECRET=your_session_secret_key_here

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URI=mongodb://localhost:27017/veo_lms

# ============================================
# REDIS CONFIGURATION (REQUIRED FOR SESSIONS)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# EMAIL SERVICE (RESEND)
# ============================================
RESEND_KEY=your_resend_api_key_here

# ============================================
# FILE STORAGE (BACKBLAZE B2 S3)
# ============================================
BLACK_BLAZE_ENDPOINT=https://s3.us-west-000.backblazeb2.com
BLACK_BLAZE_REGION=us-west-000
BLACK_BLAZE_ACCESS_KEY_ID=your_b2_application_key_id
BLACK_BLAZE_SECRET=your_b2_application_key_secret
BUCKET_NAME=your_bucket_name_here

# ============================================
# AWS S3 (COURSE THUMBNAILS & VIDEOS)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_THUMBNAIL_BUCKET=your_thumbnail_bucket_name
AWS_VIDEO_BUCKET=your_video_bucket_name

