# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Server port (default: 3000)
PORT=3000

# Session secret for cookie signing (use a strong random string)
SESSION_SECRET=your_session_secret_key_here

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MongoDB connection URL
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
# Or: mongodb://localhost:27017/database_name
DB_URL=mongodb://localhost:27017/sasta_drive

# ============================================
# REDIS CONFIGURATION
# ============================================

# Redis connection URL
# Format: redis://[:password]@host:port/database_number
REDIS_URL=redis://localhost:6379

# Redis database number (default: 0)
REDIS_DB=0

# ============================================
# CORS & CLIENT URLS
# ============================================

# Frontend application URLs (for CORS)
CLIENT_URL_1=http://localhost:3000
CLIENT_URL_2=http://localhost:5173

# ============================================
# AUTHENTICATION & GOOGLE OAUTH
# ============================================

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# ============================================
# EMAIL SERVICE (NODEMAILER)
# ============================================

# Gmail or SMTP provider password/app-specific password
# For Gmail: Generate app-specific password from https://myaccount.google.com/apppasswords
NODE_MAILER_PASS=your_email_app_password_here

# ============================================
# PAYMENT GATEWAY (RAZORPAY)
# ============================================

# Razorpay API Key ID
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_ID=your_razorpay_key_id_here

# Razorpay API Secret Key
RAZORPAY_SECRET=your_razorpay_secret_here

# Razorpay Webhook Secret (for webhook verification)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ============================================
# FILE STORAGE (BLACKBLAZE S3)
# ============================================

# Backblaze B2 S3-compatible endpoint
# Format: https://s3.region.backblazeb2.com
BLACK_BLAZE_ENDPOINT=https://s3.us-west-000.backblazeb2.com

# Backblaze B2 region code
BLACK_BLAZE_REGION=us-west-000

# Backblaze B2 application key ID
BLACK_BLAZE_ACCESS_KEY_ID=your_b2_application_key_id

# Backblaze B2 application key secret
BLACK_BLAZE_SECRET=your_b2_application_key_secret

# S3/Backblaze bucket name for storing files
BUCKET_NAME=your_bucket_name_here
